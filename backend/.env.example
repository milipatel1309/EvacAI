# Mapbox: Geocoding (/api/geocode) + Search Box (/api/resources POI). Token must allow both on api.mapbox.com.
MAPBOX_ACCESS_TOKEN=

# IBM Cloud — same API key works for IAM token (watsonx + many services)
IBM_CLOUD_API_KEY=

# Or alias (either works in code):
# WATSONX_API_KEY=

# watsonx.ai text generation
# Must be the project GUID from a watsonx / Cloud Pak project that is LINKED to a
# Watson Machine Learning (watsonx.ai runtime) service instance in your account.
# Wrong or "orphan" project IDs cause no_associated_service_instance_error — see README.
# IBM Cloud catalog (search "watsonx"): https://cloud.ibm.com/catalog?search=watsonx
WATSONX_PROJECT_ID=
# Region URL (examples: https://us-south.ml.cloud.ibm.com , https://eu-de.ml.cloud.ibm.com)
WATSONX_URL=https://us-south.ml.cloud.ibm.com
# Must be deployed / entitled in your project (override if needed):
WATSONX_MODEL_ID=ibm/granite-3-8b-instruct

# Optional: archive /api/plan JSON to IBM Cloud Object Storage (S3-compatible). Not required for watsonx.
# IBM_COS_ENDPOINT=https://s3.us-south.cloud-object-storage.appdomain.cloud
# IBM_COS_BUCKET=
# IBM_COS_RESOURCE_INSTANCE_ID=
# IBM_COS_API_KEY=
